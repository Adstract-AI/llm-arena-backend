# Django settings
PORT=8000
DJANGO_DEBUG=True

# Public hosts that are allowed to reach Django.
# Use hostnames/IPs only here, without http:// or https://.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,YOUR_SERVER_IP,YOUR_DOMAIN

# Browser-facing frontend origins.
# With the root Docker Compose + Nginx setup, frontend and backend share the same public origin,
# so use the Nginx URL, not frontend:80, backend:8000, or localhost:8000.
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://YOUR_SERVER_IP,https://YOUR_DOMAIN

# Origins allowed to submit CSRF-protected requests, such as Django admin.
# These should also be public Nginx origins, not Docker-internal service names.
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://YOUR_SERVER_IP,https://YOUR_DOMAIN

# Database configuration
# Note: No need to specify if starting locally, these are used when connecting to an external database (e.g. on Render)
#POSTGRES_HOST=
#POSTGRES_PORT =

POSTGRES_DB=llm_arena
POSTGRES_USER=llm_arena
POSTGRES_PASSWORD=llm_arena

# API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
FINKI_BASE_URL=https://pna.finki.ukim.mk/v1

# OAuth configuration
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=1

# Additional settings
AUTO_START_SETUP=true
